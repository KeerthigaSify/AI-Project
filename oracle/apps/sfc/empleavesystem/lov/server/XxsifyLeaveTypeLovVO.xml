<?xml version='1.0' encoding='windows-1252' ?>
<!DOCTYPE ViewObject SYSTEM "jbo_03_01.dtd">

<ViewObject
   Name="XxsifyLeaveTypeLovVO"
   BindingStyle="OracleName"
   CustomQuery="true"
   RowClass="oracle.apps.sfc.empleavesystem.lov.server.XxsifyLeaveTypeLovVORowImpl"
   ComponentClass="oracle.apps.sfc.empleavesystem.lov.server.XxsifyLeaveTypeLovVOImpl"
   UseGlueCode="false" >
   <SQLQuery><![CDATA[
SELECT meaning     AS MEANING,
       lookup_code AS LOOKUP_CODE
FROM   fnd_lookup_values_vl
WHERE  lookup_type  = 'XXSIFY_LEAVE_TYPE'
AND    enabled_flag = 'Y'
AND    SYSDATE BETWEEN NVL(start_date_active, SYSDATE)
                   AND NVL(end_date_active,   SYSDATE)
ORDER BY meaning
   ]]></SQLQuery>
