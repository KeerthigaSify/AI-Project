<?xml version = '1.0' encoding = 'UTF-8'?>
<page xmlns:jrad="http://xmlns.oracle.com/jrad" xmlns:oa="http://xmlns.oracle.com/oa" xmlns:ui="http://xmlns.oracle.com/uix/ui" version="10.1.3_" xml:lang="en-US" xmlns:user="http://xmlns.oracle.com/jrad/user" xmlns="http://xmlns.oracle.com/jrad" file-version="$Header$">
   <content>
      <oa:pageLayout id="pageLayoutRN" controllerClass="oracle.apps.sfc.empleavesystem.webui.XxsifyEmpLeaveSearchCO" amDefName="oracle.apps.sfc.empleavesystem.server.XxsifyEmpLeaveAM">
         <ui:corporateBranding>
            <oa:image id="corporateBrandingImage" source="/OA_MEDIA/FNDSSCORP.gif"/>
         </ui:corporateBranding>
         <ui:contents>
            <oa:header id="MainRN" text="Employee Leave Search">
               <ui:contents>

                  <!-- Search Criteria Region -->
                  <oa:rowLayout id="SearchRN" hAlign="center">
                     <ui:contents>
                        <oa:defaultSingleColumn id="SingleDefaultRN" headerDisabled="true">
                           <ui:contents>

                              <!-- Leave Type LOV -->
                              <oa:messageLovInput id="LeaveType" prompt="Leave Type" viewName="XxsifyEmpLeaveSearchVO" viewAttr="LeaveType">
                                 <lovContents>
                                    <oa:listOfValues id="LeaveTypeLov">
                                       <ui:contents>
                                          <oa:table name="LeaveTypeLov" id="XxsifyLeaveTypeLovVO">
                                             <ui:contents>
                                                <!-- Display the human-readable meaning (e.g. "Annual Leave") so users
                                                     can search and identify leave types by name. Bug fix: was showing
                                                     LookupCode (raw code) which appeared blank in the LOV column. -->
                                                <oa:messageStyledText id="LeaveTypeMeaning" viewName="XxsifyLeaveTypeLovVO" viewAttr="Meaning" queryable="true" prompt="Leave Type"/>
                                                <!-- Hidden column carries the lookup code back to the search filter -->
                                                <oa:messageStyledText id="LeaveTypeSrch" viewName="XxsifyLeaveTypeLovVO" viewAttr="LookupCode" queryable="false" prompt="Code"/>
                                             </ui:contents>
                                          </oa:table>
                                       </ui:contents>
                                    </oa:listOfValues>
                                 </lovContents>
                                 <lovMappings>
                                    <!-- Map the LookupCode (e.g. ANNUAL) into the LeaveType search field -->
                                    <lovMap id="lovMap1" lovItem="LeaveTypeSrch" resultTo="LeaveType" criteriaFrom="LeaveType"/>
                                 </lovMappings>
                              </oa:messageLovInput>

                              <!-- Start Date (search filter – optional; dataType intentionally omitted
                                   to prevent OAF from validating an empty string as a DATE when
                                   the user leaves this field blank and clicks Create/Search) -->
                              <oa:messageTextInput id="StartDate" prompt="Start Date (dd-MON-yyyy)" viewName="XxsifyEmpLeaveSearchVO" viewAttr="StartDate" required="false" displayWidth="12" maximumLength="12"/>

                              <!-- End Date (same reason as StartDate above) -->
                              <oa:messageTextInput id="EndDate" prompt="End Date (dd-MON-yyyy)" viewName="XxsifyEmpLeaveSearchVO" viewAttr="EndDate" required="false" displayWidth="12" maximumLength="12"/>

                           </ui:contents>
                        </oa:defaultSingleColumn>
                     </ui:contents>
                  </oa:rowLayout>

                  <oa:spacer id="spacer1" height="1" width="5"/>

                  <!-- Search / Clear / Create Buttons -->
                  <oa:rowLayout id="ButtonRN" hAlign="center">
                     <ui:contents>
                        <oa:pageButtonBar id="PageButtonBarRN">
                           <ui:contents>
                              <oa:submitButton id="Search" text="Search" prompt="Search" styleClass="OraDataText">
                                 <ui:primaryClientAction>
                                    <ui:firePartialAction event="Search" id="firePartialSearch"/>
                                 </ui:primaryClientAction>
                              </oa:submitButton>
                              <oa:spacer id="spacer2" width="5"/>
                              <oa:submitButton id="Clear" text="Clear" prompt="Clear" styleClass="OraDataText">
                                 <ui:primaryClientAction>
                                    <ui:firePartialAction event="Clear" id="firePartialClear"/>
                                 </ui:primaryClientAction>
                              </oa:submitButton>
                              <oa:spacer id="spacer3" width="5"/>
                              <!-- serverUnvalidated + unvalidated: skip VO-row validation on click.
                                   This is a belt-and-suspenders guard against any residual
                                   Stale Data error if the search VO row is inaccessible. -->
                              <oa:submitButton id="Create" text="Create" prompt="Create" styleClass="OraDataText" serverUnvalidated="true" unvalidated="true">
                                 <ui:primaryClientAction>
                                    <ui:firePartialAction event="Create" id="firePartialCreate"/>
                                 </ui:primaryClientAction>
                              </oa:submitButton>
                           </ui:contents>
                        </oa:pageButtonBar>
                     </ui:contents>
                  </oa:rowLayout>

                  <oa:spacer id="spacer4" width="5"/>

                  <!-- Results Table -->
                  <oa:advancedTable id="ResultsTableRN" viewName="XxsifyEmpLeaveSearchVO" width="100%" emptyText="No leave records found. Please refine your search." colFreezeEnabled="false">
                     <ui:contents>

                        <oa:column id="LeaveTypeCol">
                           <ui:columnHeader>
                              <oa:sortableHeader id="LeaveTypeHdr" prompt="Leave Type"/>
                           </ui:columnHeader>
                           <ui:contents>
                              <oa:messageTextInput id="LeaveTypeI" viewAttr="LeaveType" readOnly="true" prompt="Leave Type"/>
                           </ui:contents>
                        </oa:column>

                        <oa:column id="StartDateCol">
                           <ui:columnHeader>
                              <oa:sortableHeader id="StartDateHdr" prompt="Start Date"/>
                           </ui:columnHeader>
                           <ui:contents>
                              <oa:messageTextInput id="StartDateI" viewAttr="StartDate" readOnly="true" prompt="Start Date" dataType="DATE"/>
                           </ui:contents>
                        </oa:column>

                        <oa:column id="EndDateCol">
                           <ui:columnHeader>
                              <oa:sortableHeader id="EndDateHdr" prompt="End Date"/>
                           </ui:columnHeader>
                           <ui:contents>
                              <oa:messageTextInput id="EndDateI" viewAttr="EndDate" readOnly="true" prompt="End Date" dataType="DATE"/>
                           </ui:contents>
                        </oa:column>

                        <oa:column id="NoOfDaysCol" columnDataFormat="numberFormat">
                           <ui:columnHeader>
                              <oa:sortableHeader id="NoOfDaysHdr" prompt="No of Days"/>
                           </ui:columnHeader>
                           <ui:contents>
                              <oa:messageTextInput id="NoOfDaysI" viewAttr="NoOfDays" readOnly="true" prompt="No of Days" dataType="NUMBER"/>
                           </ui:contents>
                        </oa:column>

                        <oa:column id="StatusCol">
                           <ui:columnHeader>
                              <oa:sortableHeader id="StatusHdr" prompt="Status"/>
                           </ui:columnHeader>
                           <ui:contents>
                              <oa:messageTextInput id="StatusI" viewAttr="Status" readOnly="true" prompt="Status"/>
                           </ui:contents>
                        </oa:column>

                        <oa:column id="ReasonCol">
                           <ui:columnHeader>
                              <oa:sortableHeader id="ReasonHdr" prompt="Reason"/>
                           </ui:columnHeader>
                           <ui:contents>
                              <oa:messageTextInput id="ReasonI" viewAttr="Reason" readOnly="true" prompt="Reason"/>
                           </ui:contents>
                        </oa:column>

                        <!-- Update Icon Column -->
                        <oa:column id="UpdateCol" columnDataFormat="iconButtonFormat">
                           <ui:columnHeader>
                              <oa:sortableHeader id="UpdateHdr" prompt="Update"/>
                           </ui:columnHeader>
                           <ui:contents>
                              <oa:image id="UpdateIcon" source="updateicon_enabled.gif" prompt="Update">
                                 <ui:primaryClientAction>
                                    <ui:fireAction event="Update" id="fireActionUpdate">
                                       <ui:parameters>
                                          <ui:parameter key="leaveId" value="${oa.XxsifyEmpLeaveSearchVO.LeaveId}"/>
                                       </ui:parameters>
                                    </ui:fireAction>
                                 </ui:primaryClientAction>
                              </oa:image>
                           </ui:contents>
                        </oa:column>

                     </ui:contents>
                  </oa:advancedTable>

               </ui:contents>
            </oa:header>
         </ui:contents>
      </oa:pageLayout>
   </content>
</page>
