<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE root [
  <!ENTITY % BC4J.dtd SYSTEM "BC4J.dtd">
  %BC4J.dtd;
]>
<!--
    Sify Technologies – Employee Leave System
    Page XML   : XxsifyEmpLeaveSearchPG
    Controller : XxsifyEmpLeaveSearchCO
    AM         : XxsifyEmpLeaveAM
    VO         : XxsifyEmpLeaveSearchVO
-->
<page xmlns:jrad="http://xmlns.oracle.com/jrad"
      xmlns:ui="http://xmlns.oracle.com/uix/ui"
      xmlns:oa="http://xmlns.oracle.com/oa"
      xmlns:user="http://xmlns.oracle.com/jrad/user"
      version="9.0.3.8.22_1571"
      xml:lang="en-US">

  <content>
    <oa:pageLayout id="PageLayout"
                   pageTitle="Employee Leave Search"
                   windowTitle="Sify - Employee Leave System"
                   AM="oracle.apps.sfc.empleavesystem.server.XxsifyEmpLeaveAM"
                   controller="oracle.apps.sfc.empleavesystem.webui.XxsifyEmpLeaveSearchCO">

      <content>

        <!-- ============================================================
             Search Region
        ============================================================ -->
        <oa:query id="SearchRN"
                  searchPanelTitle="Search"
                  ViewUsageName="XxsifyEmpLeaveSearchVO"
                  AutoCustomization="true">

          <content>
            <oa:row id="SearchRow1">
              <content>

                <!-- Leave Type LOV -->
                <oa:lovItem id="LeaveTypeItem"
                            prompt="Leave Type"
                            viewName="XxsifyEmpLeaveSearchVO"
                            viewAttr="LeaveType"
                            required="false"
                            lovObjectName="XxsifyLeaveTypeLovVO"
                            CSSClass="OraFieldText"
                            columns="30">
                  <oa:lovMappings>
                    <oa:lovMap lovAttrib="LookupCode"
                               targetVOAttrib="LeaveType"
                               targetUsageName="XxsifyEmpLeaveSearchVO"/>
                  </oa:lovMappings>
                </oa:lovItem>

                <!-- Start Date -->
                <oa:messageDateField id="StartDate"
                                     prompt="Start Date"
                                     viewName="XxsifyEmpLeaveSearchVO"
                                     viewAttr="StartDate"
                                     required="false"/>

                <!-- End Date -->
                <oa:messageDateField id="EndDate"
                                     prompt="End Date"
                                     viewName="XxsifyEmpLeaveSearchVO"
                                     viewAttr="EndDate"
                                     required="false"/>

              </content>
            </oa:row>
          </content>

          <!-- Search / Clear buttons -->
          <oa:submitButton id="SearchBtn"
                           prompt="Search"
                           event="Search"/>
          <oa:submitButton id="ClearBtn"
                           prompt="Clear"
                           event="Clear"/>

        </oa:query>

        <!-- ============================================================
             Create Button
        ============================================================ -->
        <oa:submitButton id="CreateBtn"
                         prompt="Create"
                         event="Create"/>

        <!-- ============================================================
             Results Table
        ============================================================ -->
        <oa:table id="ResultsTable"
                  viewName="XxsifyEmpLeaveSearchVO"
                  title="Leave Records"
                  emptyText="No leave records found. Please refine your search."
                  width="100%">
          <content>

            <oa:column id="LeaveTypeCol"
                       prompt="Leave Type"
                       viewName="XxsifyEmpLeaveSearchVO"
                       viewAttr="LeaveType"
                       sortable="true"/>

            <oa:column id="StartDateCol"
                       prompt="Start Date"
                       viewName="XxsifyEmpLeaveSearchVO"
                       viewAttr="StartDate"
                       sortable="true"/>

            <oa:column id="EndDateCol"
                       prompt="End Date"
                       viewName="XxsifyEmpLeaveSearchVO"
                       viewAttr="EndDate"
                       sortable="true"/>

            <oa:column id="NoOfDaysCol"
                       prompt="No of Days"
                       viewName="XxsifyEmpLeaveSearchVO"
                       viewAttr="NoOfDays"/>

            <oa:column id="StatusCol"
                       prompt="Status"
                       viewName="XxsifyEmpLeaveSearchVO"
                       viewAttr="Status"/>

            <oa:column id="ReasonCol"
                       prompt="Reason"
                       viewName="XxsifyEmpLeaveSearchVO"
                       viewAttr="Reason"/>

            <!-- Update Icon column -->
            <oa:column id="UpdateCol" prompt="Update">
              <content>
                <oa:image id="UpdateIcon"
                          source="/OA_MEDIA/updateicon_enabled.gif"
                          shortDesc="Update Leave Record"
                          firePartialAction="false"
                          event="Update">
                  <oa:onSubmit>
                    <oa:firePartialActionParam name="leaveId"
                                               viewName="XxsifyEmpLeaveSearchVO"
                                               viewAttr="LeaveId"/>
                  </oa:onSubmit>
                </oa:image>
              </content>
            </oa:column>

          </content>
        </oa:table>

      </content>
    </oa:pageLayout>
  </content>

</page>
