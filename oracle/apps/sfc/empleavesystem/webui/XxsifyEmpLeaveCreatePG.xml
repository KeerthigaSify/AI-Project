<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE root [
  <!ENTITY % BC4J.dtd SYSTEM "BC4J.dtd">
  %BC4J.dtd;
]>
<!--
    Sify Technologies – Employee Leave System
    Page XML   : XxsifyEmpLeaveCreatePG
    Controller : XxsifyEmpLeaveCreateCO
    AM         : XxsifyEmpLeaveAM
    VO         : XxsifyEmpLeaveCreateVO (Entity-based)
    EO         : XxsifyEmpLeaveEO
-->
<page xmlns:jrad="http://xmlns.oracle.com/jrad"
      xmlns:ui="http://xmlns.oracle.com/uix/ui"
      xmlns:oa="http://xmlns.oracle.com/oa"
      xmlns:user="http://xmlns.oracle.com/jrad/user"
      version="9.0.3.8.22_1571"
      xml:lang="en-US">

  <content>
    <oa:pageLayout id="PageLayout"
                   pageTitle="Employee Leave Request"
                   windowTitle="Sify - Employee Leave System"
                   AM="oracle.apps.sfc.empleavesystem.server.XxsifyEmpLeaveAM"
                   controller="oracle.apps.sfc.empleavesystem.webui.XxsifyEmpLeaveCreateCO">

      <content>

        <!-- ============================================================
             Leave Details Form Header
        ============================================================ -->
        <oa:header id="FormHeader" prompt="Leave Details">
          <content>

            <!-- Employee Number – Display Only (auto from Oracle login) -->
            <oa:messageTextInput id="EmployeeNumber"
                                 prompt="Employee No"
                                 viewName="XxsifyEmpLeaveCreateVO"
                                 viewAttr="EmployeeNumber"
                                 readOnly="true"
                                 required="false"/>

            <!-- Employee Name – Display Only (auto from Oracle login) -->
            <oa:messageTextInput id="EmployeeName"
                                 prompt="Employee Name"
                                 viewName="XxsifyEmpLeaveCreateVO"
                                 viewAttr="EmployeeName"
                                 readOnly="true"
                                 required="false"/>

            <!-- Leave Type Picklist -->
            <oa:messageChoice id="LeaveType"
                              prompt="Leave Type"
                              viewName="XxsifyEmpLeaveCreateVO"
                              viewAttr="LeaveType"
                              required="true"
                              pickListVOName="XxsifyLeaveTypePicklistVO"
                              pickListDisplayAttrib="Meaning"
                              pickListValueAttrib="LookupCode"/>

            <!-- Start Date -->
            <oa:messageDateField id="StartDate"
                                 prompt="Start Date"
                                 viewName="XxsifyEmpLeaveCreateVO"
                                 viewAttr="StartDate"
                                 required="true"/>

            <!-- End Date -->
            <oa:messageDateField id="EndDate"
                                 prompt="End Date"
                                 viewName="XxsifyEmpLeaveCreateVO"
                                 viewAttr="EndDate"
                                 required="true"/>

            <!-- Calculate Period Button -->
            <oa:submitButton id="CalculatePeriodBtn"
                             prompt="Calculate Period"
                             event="CalculatePeriod"/>

            <!-- No of Leave Days – Display Only (auto-calculated) -->
            <oa:messageTextInput id="NoOfDays"
                                 prompt="No of Leave Days"
                                 viewName="XxsifyEmpLeaveCreateVO"
                                 viewAttr="NoOfDays"
                                 readOnly="true"
                                 required="false"/>

            <!-- Reason – Text Area -->
            <oa:messageTextArea id="Reason"
                                prompt="Reason"
                                viewName="XxsifyEmpLeaveCreateVO"
                                viewAttr="Reason"
                                rows="4"
                                columns="60"
                                required="true"/>

          </content>
        </oa:header>

        <!-- ============================================================
             Action Buttons
        ============================================================ -->
        <oa:submitButton id="SaveBtn"   prompt="Save"   event="Save"/>
        <oa:submitButton id="CancelBtn" prompt="Cancel" event="Cancel"/>

      </content>
    </oa:pageLayout>
  </content>

</page>
