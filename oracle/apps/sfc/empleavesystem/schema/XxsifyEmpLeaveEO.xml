  <Attribute Name="Attribute11" MaxLength="150" ColumnName="ATTRIBUTE11" SQLType="VARCHAR" Type="java.lang.String" ColumnType="VARCHAR2"/>
  <Attribute Name="Attribute12" MaxLength="150" ColumnName="ATTRIBUTE12" SQLType="VARCHAR" Type="java.lang.String" ColumnType="VARCHAR2"/>
  <Attribute Name="Attribute13" MaxLength="150" ColumnName="ATTRIBUTE13" SQLType="VARCHAR" Type="java.lang.String" ColumnType="VARCHAR2"/>
  <Attribute Name="Attribute14" MaxLength="150" ColumnName="ATTRIBUTE14" SQLType="VARCHAR" Type="java.lang.String" ColumnType="VARCHAR2"/>
